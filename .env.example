# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Zapster WhatsApp API
ZAPSTER_API_URL=https://new-api.zapsterapi.com/v1
ZAPSTER_TOKEN=your_zapster_jwt_token
ZAPSTER_INSTANCE_ID=your_zapster_instance_id
# MedShare sender number - webhook events FROM this number are ignored (outbound echo)
MEDSHARE_SENDER_PHONE=5511999999999

# Your personal WhatsApp number to receive reply notifications (with country code, no +)
OWNER_PHONE=5511999999998

# Lead message sequence delays in days
# step 0=immediate, 1=+1d, 2=+3d, 3=+7d, 4=+14d

# Blotato (Instagram scheduling)
BLOTATO_API_KEY=your_blotato_api_key
BLOTATO_ACCOUNT_ID=your_blotato_account_id
